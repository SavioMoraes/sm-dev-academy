generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Course {
  id          String        @id @default(uuid())
  playlistId  String        @unique
  title       String
  slug        String        @unique
  description String
  thumbnail   String
  playlistUrl String
  category    String
  technology  String
  level       String?
  featured    Boolean       @default(false)
  videos      CourseVideo[]
  favorites   Favorite[]
  userCourses UserCourse[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("courses")
}

model CourseVideo {
  id        String   @id @default(uuid())
  courseId  String
  videoId   String   @unique
  title     String
  thumbnail String
  position  Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_videos")
}

model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String
  role        String       @default("USER")
  avatarUrl   String?
  favorites   Favorite[]
  userCourses UserCourse[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("users")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@map("favorites")
}

model UserCourse {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  startedAt   DateTime @default(now())
  lastVideoId String?
  progress    Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, courseId])
  @@map("user_courses")
}
