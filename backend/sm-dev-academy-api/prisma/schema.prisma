generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Course {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  thumbnail   String
  videoUrl    String
  category    String
  technology  String
  level       String? 
  featured    Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}